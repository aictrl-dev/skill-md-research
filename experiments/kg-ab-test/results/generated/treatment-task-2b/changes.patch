+  /**
+   * Ensure slug uniqueness by appending numeric suffix if collision exists
+   * Only checks against non-deleted organizations
+   */
+  private async ensureUniqueSlug(baseSlug: string): Promise<string> {
+    let slug = baseSlug;
+    let suffix = 2;
+
+    while (true) {
+      const snapshot = await this.db
+        .collection('organizations')
+        .where('slug', '==', slug)
+        .where('deletedAt', '==', null)
+        .limit(1)
+        .get();
+
+      if (snapshot.empty) {
+        return slug;
+      }
+
+      slug = `${baseSlug}-${suffix}`;
+      suffix++;
+    }
+  }
