diff --git a/server/state/firestore-manager.ts b/server/state/firestore-manager.ts
index 353f7b0..950fe00 100644
--- a/server/state/firestore-manager.ts
+++ b/server/state/firestore-manager.ts
@@ -1531,6 +1531,69 @@ export class FirestoreStateManager implements IStateManager {
     log.info(`Task ${taskId} and ${features.length} features soft deleted`);
   }
 
+  /**
+   * Move a task to a different epic
+   * Also moves all associated features
+   */
+  async moveTask(taskId: string, targetEpicId: string): Promise<EpicTask> {
+    const taskRef = this.db.collection('epicTasks').doc(taskId);
+    const targetEpicRef = this.db.collection('epics').doc(targetEpicId);
+
+    // Verify task and target epic exist
+    const taskDoc = await taskRef.get();
+    const targetEpicDoc = await targetEpicRef.get();
+
+    if (!taskDoc.exists) {
+      throw new Error(`Task ${taskId} not found`);
+    }
+
+    if (!targetEpicDoc.exists) {
+      throw new Error(`Target epic ${targetEpicId} not found`);
+    }
+
+    const task = taskDoc.data() as EpicTask;
+
+    if (task.epicId === targetEpicId) {
+      throw new Error(`Task ${taskId} is already in epic ${targetEpicId}`);
+    }
+
+    const sourceEpicId = task.epicId;
+    const now = new Date().toISOString();
+
+    // Get all features for this task
+    const featuresSnapshot = await this.db.collection('features')
+      .where('taskId', '==', taskId)
+      .get();
+
+    const featuresCount = featuresSnapshot.docs.length;
+
+    // Batch update all entities atomically
+    const batch = this.db.batch();
+
+    // Update task's epicId
+    batch.update(taskRef, {
+      epicId: targetEpicId,
+      updatedAt: now,
+    });
+
+    // Update all features' epicId
+    for (const featureDoc of featuresSnapshot.docs) {
+      batch.update(featureDoc.ref, {
+        epicId: targetEpicId,
+        updatedAt: now,
+      });
+    }
+
+    await batch.commit();
+    log.info(`Task ${taskId} moved from ${sourceEpicId} to ${targetEpicId} with ${featuresCount} features`);
+
+    return {
+      ...task,
+      epicId: targetEpicId,
+      updatedAt: now,
+    };
+  }
+
